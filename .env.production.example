# BoxBox Production Environment
# Copy to .env.production and fill in all values.
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Must match POSTGRES_PASSWORD below
POSTGRES_PASSWORD=
# DATABASE_URL is constructed automatically in docker-compose.prod.yml

# Apple MapKit JS token
MAPKIT_TOKEN=

# Google OAuth credentials (from console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Domain for Caddy HTTPS (must have DNS A record pointing to this server)
DOMAIN=boxbox.example.com
